# ================================
# Fail2Ban-Report Endpoint
# ================================

# Directory Listing
Options -Indexes

# Block all but index.php
<FilesMatch "^(?!index\.php$)(?!update\.php$).*">
  Require all denied
</FilesMatch>

# Optional: IP-Whitelist
# --------------------------------
# 
# <RequireAny>
#   Require ip 192.168.1.10
#   Require ip 203.0.113.0/24
# </RequireAny>

